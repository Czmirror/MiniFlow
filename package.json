{
  "name": "miniflow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "dev:web": "pnpm --filter @miniflow/web dev",
    "dev:api": "pnpm --filter @miniflow/api dev",
    "dev": "pnpm --parallel --filter @miniflow/api --filter @miniflow/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @miniflow/api db:generate",
    "db:migrate": "pnpm --filter @miniflow/api db:migrate"
  },
  "devDependencies": {}
}
